{
  "cluster": "automatic-resolution",
  "description": "Without an effective caller choice, a sole invocable binding is selected and several invocable bindings are refused. Preference, deprecation, key order, source order, and implementation order do not invent a choice.",
  "tests": [
    {
      "description": "a sole invocable binding is selected even when deprecated and negatively preferred",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rpc": {
            "operation": "getThing",
            "source": "rpc",
            "ref": "things.v1.Things/GetThing",
            "preference": -100,
            "deprecated": true
          }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.grpc@1"],
      "expected": { "binding": "getThing.rpc" }
    },
    {
      "description": "several invocable bindings require a caller choice despite preference and deprecation metadata",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": {
            "operation": "getThing",
            "source": "rest",
            "ref": "#/paths/~1things~1{id}/get",
            "preference": 100
          },
          "getThing.rpc": {
            "operation": "getThing",
            "source": "rpc",
            "ref": "things.v1.Things/GetThing",
            "preference": 1,
            "deprecated": true
          }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "error": true, "kind": "ambiguous" }
    },
    {
      "description": "binding-key lexical order never resolves ambiguity",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" }
        },
        "bindings": {
          "getThing.z": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1z/get" },
          "getThing.a": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1a/get" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1"],
      "expected": { "error": true, "kind": "ambiguous" }
    }
  ]
}
