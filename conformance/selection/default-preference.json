{
  "cluster": "default-preference",
  "description": "Default policy, second step: within a deprecation tier, higher declared `preference` ranks first, and a candidate with no declared preference ranks below every candidate with one. Omission states no preference and is not equivalent to any numeric value, so a declared negative preference still beats an undeclared one.",
  "tests": [
    {
      "description": "higher declared preference wins (placed on the lexicographically later key, so the tiebreak cannot be what decides)",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 5 },
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 10 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.beta" }
    },
    {
      "description": "a declared preference of 0 beats an undeclared one: zero is a declaration, not the absence of one",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 0 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.beta" }
    },
    {
      "description": "a declared NEGATIVE preference beats an undeclared one: undeclared ranks below every declared value",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": -5 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.beta" }
    },
    {
      "description": "three-way: among two declared negatives and one undeclared, the higher declared negative wins",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" },
          "cli": { "bindingSpec": "openbindings.usage@1", "location": "https://example.com/things/usage.kdl" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": -7 },
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": -3 },
          "getThing.gamma": { "operation": "getThing", "source": "cli", "ref": "things get" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1", "openbindings.usage@1"],
      "expected": { "binding": "getThing.beta" }
    },
    {
      "description": "three declared preferences order by value, not by key: 9 beats 7 beats 2 wherever the keys sort",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" },
          "cli": { "bindingSpec": "openbindings.usage@1", "location": "https://example.com/things/usage.kdl" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 2 },
          "getThing.middle": { "operation": "getThing", "source": "cli", "ref": "things get", "preference": 7 },
          "getThing.zeta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 9 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1", "openbindings.usage@1"],
      "expected": { "binding": "getThing.zeta" }
    }
  ]
}
