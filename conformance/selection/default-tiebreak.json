{
  "cluster": "default-tiebreak",
  "description": "Default policy, final step: remaining ties break by lexicographic binding key, making the policy deterministic to the last step. Fixture keys are ASCII, where byte order, Unicode code-point order, and UTF-16 code-unit order coincide.",
  "tests": [
    {
      "description": "equal declared preference: the lexicographically smaller key wins",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 5 },
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 5 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.alpha" }
    },
    {
      "description": "no candidate declares a preference: the lexicographically smaller key wins",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing" },
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.alpha" }
    },
    {
      "description": "lexicographic means code-point order, not case-insensitive alphabetical: 'getThing.B' sorts before 'getThing.a'",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.a": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.B": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.B" }
    }
  ]
}
