{
  "cluster": "default-tier",
  "description": "Default policy, first step: non-deprecated candidates rank before deprecated ones. Deprecation tiering precedes every preference comparison; within the deprecated tier the same declared-preference and lexicographic rules apply, so an operation whose every candidate is deprecated still selects deterministically.",
  "tests": [
    {
      "description": "a non-deprecated candidate with a lower declared preference beats a deprecated candidate with a higher one",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 1 },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 100, "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.rest" }
    },
    {
      "description": "a non-deprecated candidate with no declared preference beats a deprecated candidate with a declared one",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 100, "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.rest" }
    },
    {
      "description": "all candidates deprecated: selection still succeeds, higher declared preference winning within the deprecated tier",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 1, "deprecated": true },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 5, "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.rpc" }
    },
    {
      "description": "all candidates deprecated: a declared negative preference beats an undeclared one within the deprecated tier",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "deprecated": true },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": -5, "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.rpc" }
    },
    {
      "description": "all candidates deprecated with equal declared preference: lexicographic binding key breaks the tie within the deprecated tier",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.alpha": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 3, "deprecated": true },
          "getThing.beta": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 3, "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "expected": { "binding": "getThing.alpha" }
    }
  ]
}
