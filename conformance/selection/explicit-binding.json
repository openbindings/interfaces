{
  "cluster": "explicit-binding",
  "description": "When the caller names a `binding`, that binding is used and selection is bypassed entirely: neither the default policy nor a configured selection override is consulted, and deprecation does not disqualify the named binding. A binding key that is not defined on the interface is an error (ERR_BINDING_NOT_FOUND).",
  "notes": "On the wire, OperationInvocationInput carries `operation` and `binding` mutually exclusively (the operation is derived from an explicit binding); each fixture carries the derived operation key alongside so operation-keyed native APIs can drive the same scenario. Whether the invoker can act on the bypassed binding's specification is an invocation concern, not a selection concern, so no fixture pins the bypass-to-unsupported-specification outcome.",
  "tests": [
    {
      "description": "an explicit binding key displaces the default policy's winner",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get", "preference": 100 },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "preference": 1 }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "binding": "getThing.rpc",
      "expected": { "binding": "getThing.rpc" }
    },
    {
      "description": "an explicit binding key selects a deprecated binding: deprecation never disqualifies an explicit choice",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing", "deprecated": true }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "binding": "getThing.rpc",
      "expected": { "binding": "getThing.rpc" }
    },
    {
      "description": "an explicit binding key that is not defined on the interface is an error",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1"],
      "binding": "getThing.nope",
      "expected": { "error": true, "kind": "unknown-binding" }
    },
    {
      "description": "an explicit binding key bypasses a configured selection override, not just the default policy",
      "document": {
        "openbindings": "0.2.0",
        "operations": { "getThing": {} },
        "sources": {
          "rest": { "bindingSpec": "openbindings.openapi@1", "location": "https://example.com/things/openapi.json" },
          "rpc": { "bindingSpec": "openbindings.grpc@1", "location": "https://example.com/things/things.protoset" }
        },
        "bindings": {
          "getThing.rest": { "operation": "getThing", "source": "rest", "ref": "#/paths/~1things~1{id}/get" },
          "getThing.rpc": { "operation": "getThing", "source": "rpc", "ref": "things.v1.Things/GetThing" }
        }
      },
      "operation": "getThing",
      "supported": ["openbindings.openapi@1", "openbindings.grpc@1"],
      "selection": ["getThing.rest"],
      "binding": "getThing.rpc",
      "expected": { "binding": "getThing.rpc" }
    }
  ]
}
