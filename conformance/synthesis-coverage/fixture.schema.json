{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbindings.com/interfaces/conformance/synthesis-coverage/fixture.schema.json",
  "title": "Interface-Synthesizer Coverage Evidence Cases",
  "type": "object",
  "required": ["format", "tests"],
  "additionalProperties": false,
  "properties": {
    "format": {
      "const": "openbindings.interface-synthesis-coverage-cases@1"
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "interface", "entries", "exhaustive", "expected"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "interface": { "type": "object" },
          "entries": { "type": "array" },
          "exhaustive": { "type": "boolean" },
          "expected": {
            "type": "object",
            "required": ["valid"],
            "additionalProperties": false,
            "properties": {
              "valid": { "type": "boolean" },
              "fullyRepresented": { "type": "boolean" },
              "errorContains": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": {
                  "properties": { "valid": { "const": true } },
                  "required": ["valid"]
                },
                "then": { "required": ["fullyRepresented"] },
                "else": { "required": ["errorContains"] }
              }
            ]
          }
        }
      }
    }
  }
}
